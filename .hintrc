{
  "extends": ["development"],
  "hints": {
    "no-inline-styles": "off",
    "axe/forms": [
      "default",
      {
        "label": "off",
      },
    ],
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "user-select",
          "mask-image",
          "mask-size",
          "mask-repeat",
          "mask-position",
        ],
      },
    ],
  },
}
